{
  "uid": "nixos-nginx",
  "title": "Nginx Traffic",
  "tags": ["nixos", "prometheus", "nginx"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": null },
        "query": "label_values(nginx_up, job)",
        "multi": true,
        "includeAll": true,
        "refresh": 1
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": null },
        "query": "label_values(nginx_up{job=~\"$job\"}, instance)",
        "multi": true,
        "includeAll": true,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Nginx Up",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "nginx_up{job=~\"$job\",instance=~\"$instance\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { 
            "mappings": [ { "type": "value", "options": { "0": { "text": "Down", "color": "red" }, "1": { "text": "Up", "color": "green" } } } ] 
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Requests per Second",
      "gridPos": { "x": 4, "y": 0, "w": 20, "h": 8 },
      "targets": [
        {
          "expr": "rate(nginx_http_requests_total{job=~\"$job\",instance=~\"$instance\"}[1m])",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Active Connections",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "nginx_connections_active{job=~\"$job\",instance=~\"$instance\"}",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Connection State",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "nginx_connections_reading{job=~\"$job\",instance=~\"$instance\"}",
          "refId": "A",
          "legendFormat": "{{instance}} Reading"
        },
        {
          "expr": "nginx_connections_writing{job=~\"$job\",instance=~\"$instance\"}",
          "refId": "B",
          "legendFormat": "{{instance}} Writing"
        },
        {
          "expr": "nginx_connections_waiting{job=~\"$job\",instance=~\"$instance\"}",
          "refId": "C",
          "legendFormat": "{{instance}} Waiting"
        }
      ]
    }
  ]
}