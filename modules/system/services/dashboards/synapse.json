{
  "uid": "nixos-synapse",
  "title": "Matrix Synapse",
  "tags": [
    "nixos",
    "prometheus",
    "matrix",
    "synapse"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Version",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "synapse_build_info{job=\"synapse\"}",
          "refId": "A",
          "legendFormat": "{{version}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "options": {
        "textMode": "name"
      },
      "id": 1,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "type": "stat",
      "title": "Monthly Active Users",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "synapse_admin_mau_current{job=\"synapse\"}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "id": 2,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "type": "stat",
      "title": "Rooms",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "synapse_notifier_rooms{job=\"synapse\"}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "purple",
                "value": null
              }
            ]
          }
        }
      },
      "id": 3,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "type": "stat",
      "title": "Memory Usage",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "jemalloc_stats_app_memory_bytes{job=\"synapse\"}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 536870912
              },
              {
                "color": "red",
                "value": 1073741824
              }
            ]
          }
        }
      },
      "id": 4,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "type": "stat",
      "title": "Federation Known Servers",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "synapse_federation_known_servers{job=\"synapse\"}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "id": 5,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "type": "stat",
      "title": "Python Version",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "python_info{job=\"synapse\"}",
          "refId": "A",
          "legendFormat": "{{version}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "options": {
        "textMode": "name"
      },
      "id": 6,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "type": "timeseries",
      "title": "Request Rate by Servlet",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(10, sum by (servlet) (rate(synapse_http_server_requests_received_total{job=\"synapse\"}[5m])))",
          "refId": "A",
          "legendFormat": "{{servlet}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "id": 7,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "type": "timeseries",
      "title": "Response Codes",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (code) (rate(synapse_http_server_responses_total{job=\"synapse\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{code}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "id": 8,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "type": "timeseries",
      "title": "Federation - Sent & Received",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(synapse_federation_client_sent_transactions_total{job=\"synapse\"}[5m])",
          "refId": "A",
          "legendFormat": "Sent Transactions",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "rate(synapse_federation_server_received_pdus_total{job=\"synapse\"}[5m])",
          "refId": "B",
          "legendFormat": "Received PDUs",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "rate(synapse_federation_client_sent_edus_total{job=\"synapse\"}[5m])",
          "refId": "C",
          "legendFormat": "Sent EDUs",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "rate(synapse_federation_server_received_edus_total{job=\"synapse\"}[5m])",
          "refId": "D",
          "legendFormat": "Received EDUs",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "id": 9,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "type": "timeseries",
      "title": "Event Processing",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(synapse_storage_events_persisted_events_sep_total{job=\"synapse\"}[5m])",
          "refId": "A",
          "legendFormat": "Events Persisted ({{type}})",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "rate(synapse_notifier_notified_events_total{job=\"synapse\"}[5m])",
          "refId": "B",
          "legendFormat": "Events Notified",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "id": 10,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "jemalloc_stats_app_memory_bytes{job=\"synapse\"}",
          "refId": "A",
          "legendFormat": "App Memory",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "id": 11,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "type": "timeseries",
      "title": "CPU Usage",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "process_cpu_user_seconds_total{job=\"synapse\"}",
          "refId": "A",
          "legendFormat": "User",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "process_cpu_system_seconds_total{job=\"synapse\"}",
          "refId": "B",
          "legendFormat": "System",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        }
      },
      "id": 12,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "type": "timeseries",
      "title": "Database Transaction Time",
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(synapse_storage_transaction_time_sum_total{job=\"synapse\"}[5m])",
          "refId": "A",
          "legendFormat": "Transaction Time",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "rate(synapse_storage_transaction_time_count_total{job=\"synapse\"}[5m])",
          "refId": "B",
          "legendFormat": "Transaction Count",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "id": 13,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "type": "timeseries",
      "title": "Active Users & Rooms",
      "gridPos": {
        "x": 12,
        "y": 28,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "synapse_admin_daily_active_users{job=\"synapse\"}",
          "refId": "A",
          "legendFormat": "Daily Active Users",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "synapse_admin_mau_current{job=\"synapse\"}",
          "refId": "B",
          "legendFormat": "Monthly Active Users",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "synapse_notifier_rooms{job=\"synapse\"}",
          "refId": "C",
          "legendFormat": "Rooms",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "id": 14,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "type": "timeseries",
      "title": "Request Duration (p99)",
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(5, histogram_quantile(0.99, sum by (servlet, le) (rate(synapse_http_server_response_time_seconds_bucket{job=\"synapse\"}[5m]))))",
          "refId": "A",
          "legendFormat": "{{servlet}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "id": 15,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "type": "timeseries",
      "title": "Reactor Tick Time",
      "gridPos": {
        "x": 12,
        "y": 36,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(python_twisted_reactor_tick_time_sum{job=\"synapse\"}[5m]) / rate(python_twisted_reactor_tick_time_count{job=\"synapse\"}[5m])",
          "refId": "A",
          "legendFormat": "Avg Tick Time",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "histogram_quantile(0.99, rate(python_twisted_reactor_tick_time_bucket{job=\"synapse\"}[5m]))",
          "refId": "B",
          "legendFormat": "p99 Tick Time",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "id": 16,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    }
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  }
}
