{
  "uid": "nixos-gpu",
  "title": "Nvidia GPU Stats",
  "tags": ["nixos", "prometheus", "gpu", "nvidia"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": null },
        "query": "label_values(nvidia_smi_utilization_gpu_ratio, job)",
        "multi": true,
        "includeAll": true,
        "refresh": 1
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": null },
        "query": "label_values(nvidia_smi_utilization_gpu_ratio{job=~\"$job\"}, instance)",
        "multi": true,
        "includeAll": true,
        "refresh": 1
      },
      {
        "name": "gpu",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": null },
        "query": "label_values(nvidia_smi_utilization_gpu_ratio{job=~\"$job\", instance=~\"$instance\"}, uuid)",
        "multi": true,
        "includeAll": true,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "type": "gauge",
      "title": "GPU Utilization",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "nvidia_smi_utilization_gpu_ratio{job=~\"$job\",instance=~\"$instance\",uuid=~\"$gpu\"}",
          "refId": "A",
          "legendFormat": "{{instance}} GPU"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 } ] } }
      }
    },
    {
      "type": "gauge",
      "title": "Memory Utilization",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "nvidia_smi_utilization_memory_ratio{job=~\"$job\",instance=~\"$instance\",uuid=~\"$gpu\"}",
          "refId": "A",
          "legendFormat": "{{instance}} Mem"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 }
      }
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "nvidia_smi_memory_used_bytes{job=~\"$job\",instance=~\"$instance\",uuid=~\"$gpu\"}",
          "refId": "A",
          "legendFormat": "{{instance}} Used"
        },
        {
          "expr": "nvidia_smi_memory_total_bytes{job=~\"$job\",instance=~\"$instance\",uuid=~\"$gpu\"}",
          "refId": "B",
          "legendFormat": "{{instance}} Total"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "type": "timeseries",
      "title": "Temperature",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "nvidia_smi_temperature_gpu{job=~\"$job\",instance=~\"$instance\",uuid=~\"$gpu\"}",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "celsius" }
      }
    }
  ]
}