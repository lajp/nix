    {
      "type": "timeseries",
      "title": "Snapshot Build Duration (p95)",
      "gridPos": {
        "x": 12,
        "y": 44,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(headscale_nodestore_snapshot_build_duration_seconds_bucket{job=\"headscale\"}[5m])))",
          "refId": "A",
          "legendFormat": "p95",
          "datasource": {
            "type": "prometheus",
