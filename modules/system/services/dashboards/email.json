{
  "uid": "email-services",
  "title": "Email Services",
  "tags": ["nixos", "prometheus", "email", "postfix", "dovecot", "rspamd"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": null },
        "query": "label_values(up{job=~\"postfix|dovecot|rspamd\"}, job)",
        "multi": true,
        "includeAll": true,
        "refresh": 1
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": null },
        "query": "label_values(up{job=~\"$job\"}, instance)",
        "multi": true,
        "includeAll": true,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Service Status",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 4 },
      "targets": [
        {
          "expr": "up{job=~\"$job\", instance=~\"$instance\"}",
          "legendFormat": "{{job}} - {{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Down", "color": "red" }, "1": { "text": "Up", "color": "green" } } }
          ]
        }
      }
    },
    {
      "type": "row",
      "title": "Postfix",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 1 }
    },
    {
      "type": "stat",
      "title": "Total Incoming Messages",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 4 },
      "targets": [
        {
          "expr": "sum(postfix_smtpd_messages_processed_total{instance=~\"$instance\"})",
          "legendFormat": "Total Incoming"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "type": "stat",
      "title": "Total Sent Messages",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 4 },
      "targets": [
        {
          "expr": "sum(postfix_smtp_messages_processed_total{instance=~\"$instance\", status=\"sent\"})",
          "legendFormat": "Total Sent"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "type": "timeseries",
      "title": "Postfix Queue Depth",
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(postfix_showq_queue_depth{instance=~\"$instance\"}) by (queue)",
          "legendFormat": "{{queue}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "type": "timeseries",
      "title": "Postfix Mail Activity",
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(postfix_smtpd_messages_processed_total{instance=~\"$instance\"}[5m])",
          "legendFormat": "Processed (Incoming)"
        },
        {
          "expr": "rate(postfix_smtp_messages_processed_total{instance=~\"$instance\", status=\"sent\"}[5m])",
          "legendFormat": "Sent (Outgoing)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "mps" }
      }
    },
    {
      "type": "row",
      "title": "Dovecot",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 17, "w": 24, "h": 1 }
    },
    {
      "type": "stat",
      "title": "Dovecot Status",
      "gridPos": { "x": 0, "y": 18, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "dovecot_up{instance=~\"$instance\"}",
          "legendFormat": "Dovecot Up"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Down", "color": "red" }, "1": { "text": "Up", "color": "green" } } }
          ]
        }
      }
    },
    {
      "type": "row",
      "title": "Rspamd",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 1 }
    },
    {
      "type": "stat",
      "title": "Rspamd Scanned",
      "gridPos": { "x": 0, "y": 27, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "increase(rspamd_scanned{instance=~\"$instance\"}[1h])",
          "legendFormat": "Scanned (1h)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Rspamd Ham",
      "gridPos": { "x": 6, "y": 27, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "increase(rspamd_ham_count{instance=~\"$instance\"}[1h])",
          "legendFormat": "Ham (1h)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Rspamd Spam",
      "gridPos": { "x": 12, "y": 27, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "increase(rspamd_spam_count{instance=~\"$instance\"}[1h])",
          "legendFormat": "Spam (1h)"
        }
      ]
    }
  ]
}