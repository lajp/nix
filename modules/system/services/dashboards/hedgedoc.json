{
  "uid": "nixos-hedgedoc",
  "title": "HedgeDoc",
  "tags": ["nixos", "prometheus", "hedgedoc"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Total Notes",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "hedgedoc_notes{job=\"hedgedoc\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Online Notes",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "hedgedoc_online_notes{job=\"hedgedoc\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Online Users",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "hedgedoc_online_users{job=\"hedgedoc\",type=\"all\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Registered Users",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "hedgedoc_registered_users{job=\"hedgedoc\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Memory Usage",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"hedgedoc\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 268435456 },
              { "color": "red", "value": 536870912 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Version",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "app_version{job=\"hedgedoc\"}",
          "refId": "A",
          "legendFormat": "{{version}}"
        }
      ],
      "options": {
        "textMode": "name"
      }
    },
    {
      "type": "timeseries",
      "title": "Online Activity",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "hedgedoc_online_notes{job=\"hedgedoc\"}",
          "refId": "A",
          "legendFormat": "Online Notes"
        },
        {
          "expr": "hedgedoc_online_users{job=\"hedgedoc\",type=\"all\"}",
          "refId": "B",
          "legendFormat": "Online Users (All)"
        },
        {
          "expr": "hedgedoc_online_users{job=\"hedgedoc\",type=\"signed-in\"}",
          "refId": "C",
          "legendFormat": "Online Users (Signed In)"
        },
        {
          "expr": "hedgedoc_online_sessions{job=\"hedgedoc\",type=\"all\"}",
          "refId": "D",
          "legendFormat": "Sessions (All)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Total Notes Over Time",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "hedgedoc_notes{job=\"hedgedoc\"}",
          "refId": "A",
          "legendFormat": "Total Notes"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Rate by Route",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_request_duration_seconds_count{job=\"hedgedoc\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Response Codes",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (code) (rate(http_request_duration_seconds_count{job=\"hedgedoc\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"hedgedoc\"}",
          "refId": "A",
          "legendFormat": "Resident"
        },
        {
          "expr": "nodejs_heap_size_used_bytes{job=\"hedgedoc\"}",
          "refId": "B",
          "legendFormat": "Heap Used"
        },
        {
          "expr": "nodejs_heap_size_total_bytes{job=\"hedgedoc\"}",
          "refId": "C",
          "legendFormat": "Heap Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "CPU Usage",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"hedgedoc\"}[5m])",
          "refId": "A",
          "legendFormat": "CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Connection Status",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "hedgedoc_connection_busy{job=\"hedgedoc\"}",
          "refId": "A",
          "legendFormat": "Busy Connections"
        },
        {
          "expr": "hedgedoc_connection_socket_queue_length{job=\"hedgedoc\"}",
          "refId": "B",
          "legendFormat": "Socket Queue"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Event Loop Lag",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_mean_seconds{job=\"hedgedoc\"}",
          "refId": "A",
          "legendFormat": "Mean"
        },
        {
          "expr": "nodejs_eventloop_lag_p99_seconds{job=\"hedgedoc\"}",
          "refId": "B",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    }
  ]
}
